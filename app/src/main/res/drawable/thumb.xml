<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:width="32dp" android:height="32dp" android:gravity="center">
        <shape android:shape="oval" >
            <gradient
                android:angle="60"
                android:type="linear"
                android:endColor="#FF2E2E2E"
                android:startColor="#FF474747" />
        </shape>
    </item>
    <item android:width="4dp" android:height="31dp" android:gravity="center" android:right="12dp" android:left="20dp">
        <shape android:shape="rectangle" >
            <gradient
                android:angle="0"
                android:type="linear"
                android:endColor="#00000000"
                android:startColor="#66000000" />
        </shape>
    </item>
    <item android:width="4dp" android:height="31dp" android:gravity="center" android:right="20dp" android:left="12dp">
        <shape android:shape="rectangle" >
            <gradient
                android:angle="180"
                android:type="linear"
                android:endColor="#006F6F6F"
                android:startColor="#386F6F6F" />
        </shape>
    </item>
    <item android:width="4dp" android:height="31dp" android:gravity="center">
        <shape android:shape="rectangle" >
            <gradient
                android:angle="90"
                android:type="linear"
                android:endColor="#FF737373"
                android:startColor="#FF3A3A3A" />
        </shape>
    </item>
</layer-list>