<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:width="90dp" android:height="90dp">
        <shape android:shape="oval" >
            <solid android:color="#32000000" />
        </shape>
    </item>
    <item android:width="72dp" android:height="72dp" android:gravity="center">
        <shape android:shape="oval" >
            <gradient
                android:angle="90"
                android:type="linear"
                android:startColor="#474747"
                android:endColor="#151515" />
            <stroke
                android:width="0.3dp"
                android:color="#666666" />
        </shape>
    </item>
    <item
        android:width="72dp"
        android:height="72dp"
        android:gravity="center"
        android:top="4dp"
        android:left="4dp">

        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="38dp"
                android:startColor="#99000000"
            android:endColor="#00000000"
            android:centerX="50%"
            android:centerY="50%" />
        </shape>
    </item>
    <item android:width="58dp" android:height="58dp" android:gravity="center">
        <shape android:shape="oval" >
            <gradient
                android:angle="90"
                android:type="linear"
                android:startColor="#181818"
                android:endColor="#424242" />
        </shape>
    </item>
    <item
        android:id="@+id/LineTimer"
        android:width="4dp"
        android:height="24dp"
        android:left="43dp"
        android:right="43dp"
        android:top="21dp"
        android:bottom="45dp">
        <rotate
            android:fromDegrees="0"
            android:toDegrees="360"
            android:pivotX="50%"
            android:pivotY="100%">
            <shape android:shape="rectangle">
                <solid android:color="#C50000" />
                <corners android:radius="45dp" />
            </shape>
        </rotate>
    </item>
</layer-list>